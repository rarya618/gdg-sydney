        <a href="https://www.meetup.com/gdgcloudsydney/" target="_blank" rel="noopener noreferrer" class="footer-social-link" aria-label="Meetup">
          <svg viewBox="0 0 24 24" width="32" height="32" fill="currentColor" aria-hidden="true"><path d="M19.24 12.59a3.54 3.54 0 0 0-.89-1.66 3.1 3.1 0 0 0 .23-2.41 3.18 3.18 0 0 0-1.88-2 3.21 3.21 0 0 0-3.08.47 3.1 3.1 0 0 0-2.08-.8 3.14 3.14 0 0 0-2.34 1.05 3.54 3.54 0 0 0-1.56-.13 3.22 3.22 0 0 0-2.64 2.35 3.21 3.21 0 0 0 .6 2.88 3.51 3.51 0 0 0-.1 2.45 3.24 3.24 0 0 0 2.09 2.05 3.16 3.16 0 0 0 2.56-.32 3.14 3.14 0 0 0 2.33.57 3.13 3.13 0 0 0 1.92-1 3.57 3.57 0 0 0 2.07.21 3.24 3.24 0 0 0 2.43-2.13 3.52 3.52 0 0 0-.66-2.58zm-7.74 3.4a2.06 2.06 0 1 1 2.06-2.06 2.06 2.06 0 0 1-2.06 2.06z"/></svg>
        </a>
        <a href="https://www.linkedin.com/company/gdg-sydney/" target="_blank" rel="noopener noreferrer" class="footer-social-link" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
