        <a href="https://www.instagram.com/gdgsydney" target="_blank" rel="noopener noreferrer" class="footer-social-link" aria-label="Instagram">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
        </a>
      </div>
    </div>

  </div>
  <div class="footer-base">
    <div class="container">
      <p class="footer-legal">
        &copy; {year} GDG Sydney. GDG Sydney is an independently-run community group
        and is not an official Google product or service.
      </p>
    </div>
  </div>
</footer>

<style>
  :root {
    --blue:   #4285F4;
    --green:  #34A853;
    --yellow: #f9ab00;
    --red:    #EA4335;
    --dark:   #1e1e1e;
    --sans:   'Google Sans', system-ui, -apple-system, sans-serif;
  }

  .container {
    max-width: 1160px;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 3rem);
  }

  .logo-img-footer { height: 26px; width: auto; display: block; flex-shrink: 0; }

  .footer {
    background: var(--dark);
    color: rgba(255, 255, 255, 0.65);
  }

  .footer-accent {
    display: flex;
    height: 3px;
  }
  .footer-accent span { flex: 1; }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  @media (min-width: 640px) {
    .footer-inner {
      grid-template-columns: 1.8fr 1fr 1fr;
      gap: 4rem;
      align-items: start;
    }
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 2px;
    margin-bottom: 0.875rem;
  }

  .footer-wordmark {
    font-size: 1.2rem;
    font-weight: 700;
    color: white;
  }

  .footer-tagline {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.48);
    max-width: 220px;
    line-height: 1.75;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-col-label {
    font-family: var(--sans);
    font-size: 0.7rem;
    text-transform: uppercase;
    font-weight: 800;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.45);
    margin-bottom: 0.25rem;
  }

  .footer-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .footer-link:hover { color: white; }

  .footer-socials {
    display: flex;
    gap: 0.625rem;
    margin-top: 0.5rem;
  }

  .footer-social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    color: rgba(255, 255, 255, 0.75);
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.18);
    transition: color 0.15s ease, background 0.15s ease, border-color 0.15s ease;
  }

  .footer-social-link:hover {
    color: white;
    background: rgba(255, 255, 255, 0.16);
    border-color: rgba(255, 255, 255, 0.35);
  }

  .footer-base {
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    padding-block: 1.5rem;
  }

  .footer-legal {
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.38);
    line-height: 1.65;
  }
</style>
