---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <meta name="description" content="Speak at a GDG Sydney meetup. Share your knowledge with Sydney's developer community. All experience levels welcome." />
  <title>Speak at GDG Sydney | Google Developer Group</title>
  <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />
  <meta property="og:site_name" content="GDG Sydney" />
  <meta property="og:title" content="Speak at GDG Sydney" />
  <meta property="og:description" content="Share your knowledge with Sydney's developer community. All experience levels welcome, from lightning talks to deep dives." />
  <meta property="og:image" content={new URL('/logo.png', Astro.site)} />
  <meta property="og:image:alt" content="GDG Sydney logo" />
  <meta property="og:locale" content="en_AU" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content="Speak at GDG Sydney" />
  <meta name="twitter:description" content="Share your knowledge with Sydney's developer community. All experience levels welcome." />
  <meta name="twitter:image" content={new URL('/logo.png', Astro.site)} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- ═══════════════════════════════ HEADER ═══════════════════════════════ -->
  <header class="header">
    <div class="container header-inner">
      <a href="/" class="logo" aria-label="GDG Sydney home">
        <img src="/logo.png" alt="" class="logo-img" aria-hidden="true" />
        <span class="logo-wordmark">GDG Sydney</span>
      </a>
      <nav class="header-nav" aria-label="Main navigation">
        <a href="/#events" class="nav-link">Events</a>
        <a href="/speak" class="nav-link" aria-current="page">Speak</a>
        <a
          href="https://gdg.community.dev/gdg-sydney/"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary btn-sm"
        >
          Join the community
        </a>
      </nav>
    </div>
  </header>

  <!-- ══════════════════════════════ MASTHEAD ══════════════════════════════ -->
  <section class="speak-masthead" aria-labelledby="speak-heading">
    <div class="container">
      <div class="speak-masthead-inner">
        <div class="speak-masthead-text">
          <h1 class="speak-heading" id="speak-heading">
            Share your<br />knowledge.
          </h1>
          <p class="speak-subheading">
            Speak at a GDG Sydney meetup
          </p>
        </div>
        <div class="speak-stats" aria-label="Community stats">
          <div class="stat">
            <span class="stat-value">2,000<span class="stat-plus">+</span></span>
            <span class="stat-label">Members</span>
          </div>
          <div class="stat-divider" aria-hidden="true"></div>
          <div class="stat">
            <span class="stat-value">Monthly</span>
            <span class="stat-label">Meetups</span>
          </div>
          <div class="stat-divider" aria-hidden="true"></div>
          <div class="stat">
            <span class="stat-value">All</span>
            <span class="stat-label">Levels</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════ MAIN ═════════════════════════════════ -->
  <main class="speak-body" id="main-content">
    <div class="container">
      <div class="speak-layout">

        <!-- Left: info -->
        <aside class="speak-info" aria-label="Why speak at GDG Sydney">

          <div class="info-block">
            <p class="info-label">Why speak?</p>
            <ul class="info-list" role="list">
              <li class="info-item">
                <span class="info-dot" style="background: var(--blue)"></span>
                Share expertise with a passionate, engaged audience
              </li>
              <li class="info-item">
                <span class="info-dot" style="background: var(--green)"></span>
                Build your profile in the Sydney tech community
              </li>
              <li class="info-item">
                <span class="info-dot" style="background: var(--yellow)"></span>
                All experience levels welcome, first talk or hundredth
              </li>
              <li class="info-item">
                <span class="info-dot" style="background: var(--red)"></span>
                Google and non-Google topics both encouraged
              </li>
            </ul>
          </div>

          <div class="info-block">
            <p class="info-label">Talk formats</p>
            <div class="format-cards">
              <div class="format-card">
                <span class="format-tag" style="--tag-color: var(--blue)">Lightning</span>
                <p class="format-duration">5 – 10 min</p>
                <p class="format-desc">A focused demo, quick tip, or intro to a tool.</p>
              </div>
              <div class="format-card">
                <span class="format-tag" style="--tag-color: var(--green)">Standard</span>
                <p class="format-duration">20 – 30 min</p>
                <p class="format-desc">A full talk with time for audience questions.</p>
              </div>
            </div>
          </div>

          <div class="info-block">
            <p class="info-label">Questions?</p>
            <a href="mailto:hello@gdgsydney.com" class="info-email">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="15" height="15" aria-hidden="true">
                <path d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              hello@gdgsydney.com
            </a>
          </div>

        </aside>

        <!-- Right: form -->
        <section class="speak-form-wrap" aria-labelledby="form-heading">
          <h2 class="form-heading" id="form-heading">Submit a talk proposal</h2>

          <form
            class="speak-form"
            novalidate
            id="speaker-form"
          >

            <!-- Name + Email -->
            <div class="field-row">
              <div class="field">
                <label for="name" class="field-label">Full name <span class="required" aria-hidden="true">*</span></label>
                <input
                  id="name"
                  name="name"
                  type="text"
                  class="field-input"
                  placeholder="Alex Chen"
                  required
                  autocomplete="name"
                />
              </div>
              <div class="field">
                <label for="email" class="field-label">Email <span class="required" aria-hidden="true">*</span></label>
                <input
                  id="email"
                  name="email"
                  type="email"
                  class="field-input"
                  placeholder="alex@example.com"
                  required
                  autocomplete="email"
                />
              </div>
            </div>

            <!-- LinkedIn / website -->
            <div class="field">
              <label for="profile" class="field-label">
                LinkedIn or website
                <span class="field-optional">(optional)</span>
              </label>
              <input
                id="profile"
                name="profile"
                type="url"
                class="field-input"
                placeholder="https://linkedin.com/in/yourname"
                autocomplete="url"
              />
            </div>

            <!-- Talk title -->
            <div class="field">
              <label for="title" class="field-label">Talk title <span class="required" aria-hidden="true">*</span></label>
              <input
                id="title"
                name="title"
                type="text"
                class="field-input"
                placeholder="e.g. Building RAG apps with Vertex AI"
                required
              />
            </div>

            <!-- Format -->
            <fieldset class="field">
              <legend class="field-label">Talk format <span class="required" aria-hidden="true">*</span></legend>
              <div class="radio-group" role="radiogroup">
                <label class="radio-card">
                  <input type="radio" name="format" value="lightning" required />
                  <span class="radio-inner">
                    <span class="radio-name">Lightning talk</span>
                    <span class="radio-sub">5 – 10 minutes</span>
                  </span>
                </label>
                <label class="radio-card">
                  <input type="radio" name="format" value="standard" required />
                  <span class="radio-inner">
                    <span class="radio-name">Standard talk</span>
                    <span class="radio-sub">20 – 30 minutes</span>
                  </span>
                </label>
              </div>
            </fieldset>

            <!-- Abstract -->
            <div class="field">
              <label for="abstract" class="field-label">
                Talk abstract <span class="required" aria-hidden="true">*</span>
              </label>
              <p class="field-hint">What will attendees learn? What problem does it solve?</p>
              <textarea
                id="abstract"
                name="abstract"
                class="field-input field-textarea"
                placeholder="A short description of your talk. 2 to 4 sentences is ideal."
                rows="3"
                required
              ></textarea>
            </div>

            <!-- Target audience -->
            <div class="field">
              <label for="audience" class="field-label">
                Target audience <span class="required" aria-hidden="true">*</span>
              </label>
              <p class="field-hint">Who will get the most out of this talk? What level of experience should they have?</p>
              <textarea
                id="audience"
                name="audience"
                class="field-input field-textarea"
                placeholder="e.g. Developers curious about AI, no prior ML experience needed. Or: backend engineers familiar with distributed systems."
                rows="3"
                required
              ></textarea>
            </div>

            <!-- Bio -->
            <div class="field">
              <label for="bio" class="field-label">
                Speaker bio <span class="required" aria-hidden="true">*</span>
              </label>
              <p class="field-hint">A few sentences about you and your background.</p>
              <textarea
                id="bio"
                name="bio"
                class="field-input field-textarea"
                placeholder="I'm a software engineer at ... with experience in ..."
                rows="3"
                required
              ></textarea>
            </div>

            <!-- Experience -->
            <div class="field">
              <label for="experience" class="field-label">
                Speaking experience
                <span class="field-optional">(optional)</span>
              </label>
              <textarea
                id="experience"
                name="experience"
                class="field-input field-textarea"
                placeholder="Have you spoken at meetups or conferences before? Doesn't matter if not. First-time speakers are very welcome."
                rows="3"
              ></textarea>
            </div>

            <!-- Anything else -->
            <div class="field">
              <label for="notes" class="field-label">
                Anything else?
                <span class="field-optional">(optional)</span>
              </label>
              <textarea
                id="notes"
                name="notes"
                class="field-input field-textarea"
                placeholder="Preferred dates, AV requirements, co-presenter, etc."
                rows="3"
              ></textarea>
            </div>

            <div class="form-footer">
              <p class="form-note">
                <span class="required" aria-hidden="true">*</span> Required fields.
                We'll get back to you within a week.
              </p>
              <button type="submit" class="btn btn-primary btn-submit" id="submit-btn">
                Submit proposal
                <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16" aria-hidden="true">
                  <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd" />
                </svg>
              </button>
            </div>

          </form>

          <div class="form-success" id="form-success" hidden aria-live="polite">
            <div class="success-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="28" height="28">
                <path d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="success-title">Proposal received!</h3>
            <p class="success-body">Thanks for putting your hand up. We'll be in touch within a week.</p>
          </div>

          <div class="form-error" id="form-error" hidden aria-live="polite">
            <p class="error-text">Something went wrong. Please try again or email us at <a href="mailto:hello@gdgsydney.com" class="coc-link">hello@gdgsydney.com</a>.</p>
          </div>

        </section>

      </div>
    </div>
  </main>

  <script>
    const SHEET_URL = import.meta.env.PUBLIC_SPEAKER_FORM_URL;

    const form = document.getElementById('speaker-form') as HTMLFormElement;
    const btn = document.getElementById('submit-btn') as HTMLButtonElement;
    const successEl = document.getElementById('form-success') as HTMLElement;
    const errorEl = document.getElementById('form-error') as HTMLElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.checkValidity()) { form.reportValidity(); return; }

      btn.disabled = true;
      btn.textContent = 'Submitting...';

      const data = Object.fromEntries(new FormData(form));

      try {
        await fetch(SHEET_URL, {
          method: 'POST',
          mode: 'no-cors',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        form.hidden = true;
        errorEl.hidden = true;
        successEl.hidden = false;
      } catch {
        btn.disabled = false;
        btn.textContent = 'Submit proposal';
        errorEl.hidden = false;
      }
    });
  </script>

  <!-- ══════════════════════════════ FOOTER ════════════════════════════════ -->
  <Footer />

</body>
</html>

<style is:global>
  /* ─── Reset & Base ──────────────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  :root {
    --blue:   #4285F4;
    --green:  #34A853;
    --yellow: #f9ab00;
    --red:    #EA4335;

    --bg:     #f5f4f0;
    --dark:   #1e1e1e;
    --text:   #2a2a2a;
    --muted:  #6b7280;
    --white:  #ffffff;
    --border: rgba(0, 0, 0, 0.09);

    --sans: 'Google Sans', system-ui, -apple-system, sans-serif;
    --mono: 'JetBrains Mono', 'Roboto Mono', monospace;

    --header-h: 68px;
  }

  body {
    font-family: var(--sans);
    background: var(--bg);
    color: var(--text);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }

  .container {
    max-width: 1160px;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 3rem);
  }

  /* ─── Header ────────────────────────────────────────────────────────── */
  .header {
    position: fixed;
    inset-inline: 0;
    top: 0;
    height: var(--header-h);
    background: rgba(245, 244, 240, 0.85);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border-bottom: 1px solid var(--border);
    z-index: 100;
    display: flex;
    align-items: center;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 2px;
    text-decoration: none;
    color: var(--dark);
  }

  .logo-img {
    height: 28px;
    width: auto;
    display: block;
    flex-shrink: 0;
  }

  .logo-img-footer { height: 26px; }

  .logo-wordmark {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--dark);
  }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .nav-link:hover { color: var(--dark); }

  /* ─── Buttons ───────────────────────────────────────────────────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    border-radius: 100px;
    font-family: var(--sans);
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    cursor: pointer;
    border: none;
    line-height: 1;
  }
  .btn:hover  { transform: translateY(-1px); }
  .btn:active { transform: translateY(0); }
  .btn-sm { padding: 0.6em 1.4em; font-size: 0.825rem; }

  .btn-primary {
    background: var(--blue);
    color: white;
    box-shadow: 0 1px 6px rgba(66, 133, 244, 0.28);
  }
  .btn-primary:hover {
    box-shadow: 0 4px 18px rgba(66, 133, 244, 0.42);
  }

  /* ─── Speak masthead ────────────────────────────────────────────────── */
  .speak-masthead {
    padding-top: calc(var(--header-h) + 4rem);
    padding-bottom: 3.5rem;
    border-bottom: 1px solid var(--border);
  }

  .speak-masthead-inner {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  @media (min-width: 700px) {
    .speak-masthead-inner {
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
    }
  }

  .speak-heading {
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 800;
    line-height: 1.0;
    letter-spacing: -0.04em;
    color: var(--dark);
    margin-bottom: 0.75rem;
  }

  .speak-subheading {
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .speak-stats {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-shrink: 0;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .stat-value {
    font-size: 1.35rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--dark);
    line-height: 1;
  }

  .stat-plus {
    color: var(--blue);
  }

  .stat-label {
    font-family: var(--sans);
    font-size: 0.62rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
  }

  .stat-divider {
    width: 1px;
    height: 2.5rem;
    background: var(--border);
    flex-shrink: 0;
  }

  /* ─── Speak layout ──────────────────────────────────────────────────── */
  .speak-body {
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  .speak-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3.5rem;
  }

  @media (min-width: 960px) {
    .speak-layout {
      grid-template-columns: 260px 1fr;
      gap: 5rem;
      align-items: start;
    }
  }

  /* ─── Info sidebar ──────────────────────────────────────────────────── */
  .speak-info {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  @media (min-width: 960px) {
    .speak-info {
      position: sticky;
      top: calc(var(--header-h) + 2rem);
    }
  }

  .info-block {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .info-label {
    font-family: var(--sans);
    font-size: 0.62rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
  }

  .info-list {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    list-style: none;
  }

  .info-item {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: 0.875rem;
    line-height: 1.6;
    color: #4a4a4a;
  }

  .info-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 0.42em;
  }

  .format-cards {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .format-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1rem 1.125rem;
  }

  .format-tag {
    display: inline-block;
    font-family: var(--sans);
    font-size: 0.62rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--tag-color);
    margin-bottom: 0.3rem;
  }

  .format-duration {
    font-size: 1rem;
    font-weight: 700;
    color: var(--dark);
    letter-spacing: -0.02em;
    margin-bottom: 0.3rem;
  }

  .format-desc {
    font-size: 0.8rem;
    color: var(--muted);
    line-height: 1.55;
  }

  .info-email {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--blue);
    text-decoration: none;
    transition: opacity 0.15s ease;
  }
  .info-email:hover { opacity: 0.75; }

  /* ─── Form ──────────────────────────────────────────────────────────── */
  .speak-form-wrap {
    min-width: 0;
  }

  .form-heading {
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--dark);
    margin-bottom: 2rem;
    line-height: 1.15;
  }

  .speak-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .field-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 560px) {
    .field-row { grid-template-columns: 1fr 1fr; }
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .field-label {
    font-size: 0.825rem;
    font-weight: 600;
    color: var(--dark);
  }

  .field-optional {
    font-weight: 400;
    color: var(--muted);
    margin-left: 0.25rem;
  }

  .field-hint {
    font-size: 0.78rem;
    color: var(--muted);
    line-height: 1.5;
    margin-top: -0.1rem;
  }

  .required { color: var(--red); }

  .field-input {
    font-family: var(--sans);
    font-size: 0.9rem;
    color: var(--text);
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.7rem 0.875rem;
    outline: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
    width: 100%;
  }

