---
import '../styles/global.css';

const BEVY_API = 'https://gdg.community.dev/api/event_slim/for_chapter/539/?page_size=10&status=Live&include_cohosted_events=true&visible_on_parent_chapter_only=true&order=start_date&fields=title,start_date,event_type_title,url,description_short&page=1';

interface BevyEvent {
  title: string;
  start_date: string;
  event_type_title: string;
  url: string;
  description_short: string;
}

let upcomingEvents: BevyEvent[] = [];
try {
  const res = await fetch(BEVY_API);
  const data = await res.json();
  upcomingEvents = data.results ?? [];
} catch (e) {
  upcomingEvents = [];
}

function formatEventDate(iso: string) {
  const d = new Date(iso);
  return d.toLocaleDateString('en-AU', { weekday: 'short', day: 'numeric', month: 'long', year: 'numeric', timeZone: 'Australia/Sydney' });
}

function formatEventTime(iso: string) {
  const d = new Date(iso);
  return d.toLocaleTimeString('en-AU', { hour: 'numeric', minute: '2-digit', hour12: true, timeZone: 'Australia/Sydney' });
}

function classifyEvent(event: BevyEvent): { label: string; accent: string } {
  if (/meetup/i.test(event.title)) return { label: 'Meetup', accent: 'yellow' };
  if (event.event_type_title === 'Workshop / Study Group') return { label: 'Workshop', accent: 'green' };
  return { label: 'Talk', accent: 'blue' };
}

interface BevySponsor {
  company: string;
  description: string;
  url: string;
  logo: string;
  sponsor_type: string;
}

let partners: BevySponsor[] = [];
try {
  const res = await fetch('https://gdg.community.dev/api/chapter_slim/gdg-sydney/sponsors/');
  partners = await res.json();
} catch (e) {
  partners = [];
}

let memberCount = '2,000';
try {
  const res = await fetch('https://gdg.community.dev/api/chapter_slim/gdg-sydney/');
  const data = await res.json();
  if (data.members_count) {
    memberCount = data.members_count.toLocaleString('en-AU');
  }
} catch (e) {
  memberCount = '2,000+';
}

interface BevyPastEvent {
  title: string;
  start_date: string;
  event_type_title: string;
  url: string;
}

let pastEvents: BevyPastEvent[] = [];
let totalEventCount = 0;
try {
  const res = await fetch('https://gdg.community.dev/api/event_slim/for_chapter/539/?page_size=4&status=Completed&include_cohosted_events=true&visible_on_parent_chapter_only=true&order=-start_date&fields=title,start_date,event_type_title,url&page=1');
  const data = await res.json();
  pastEvents = data.results ?? [];
  totalEventCount = data.count ?? 0;
} catch (e) {
  pastEvents = [];
}

interface BevyTeamMember {
  user: {
    full_name: string;
    title: string;
    company: string;
    bio: string;
    profile_url: string;
    avatar: { thumbnail_url: string; };
  };
  title: string;
}

let team: BevyTeamMember[] = [];
try {
  const res = await fetch('https://gdg.community.dev/api/chapter_slim/gdg-sydney/team/');
  team = await res.json();
} catch (e) {
  team = [];
}
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <meta name="description" content="GDG Sydney, Google Developer Group Sydney. Connecting developers, designers, and tech enthusiasts across the city." />
  <title>GDG Sydney | Google Developer Group</title>
  <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />
  <meta property="og:site_name" content="GDG Sydney" />
  <meta property="og:title" content="GDG Sydney | Google Developer Group" />
  <meta property="og:description" content="A vibrant hub for tech innovators in Sydney. 2,000+ developers, designers, and tech enthusiasts connecting, learning, and growing together." />
  <meta property="og:image" content={new URL('/operaHouse.png', Astro.site)} />
  <meta property="og:image:alt" content="Sydney Opera House illustration" />
  <meta property="og:locale" content="en_AU" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="GDG Sydney | Google Developer Group" />
  <meta name="twitter:description" content="A vibrant hub for tech innovators in Sydney. 2,000+ developers, designers, and tech enthusiasts connecting, learning, and growing together." />
  <meta name="twitter:image" content={new URL('/operaHouse.png', Astro.site)} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- ═══════════════════════════════ HEADER ═══════════════════════════════ -->
  <header class="header">
    <div class="container header-inner">
      <a href="/" class="logo" aria-label="GDG Sydney home">
        <img src="/logo.png" alt="" class="logo-img" aria-hidden="true" />
        <span class="logo-wordmark">GDG Sydney</span>
      </a>
      <nav class="header-nav" aria-label="Main navigation">
        <a href="#events" class="nav-link">Events</a>
        <a href="/speak" class="nav-link">Speak</a>
        <a
          href="https://gdg.community.dev/gdg-sydney/"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary btn-sm"
        >
          Join the community
        </a>
      </nav>
    </div>
  </header>

  <!-- ════════════════════════════════ HERO ════════════════════════════════ -->
  <section class="hero" id="home" aria-labelledby="hero-heading">
    <div class="hero-illustration" aria-hidden="true">
      <img src="/operaHouse.png" alt="" aria-hidden="true" />
    </div>

    <div class="container">
      <div class="hero-content">
        <h1 class="hero-heading" id="hero-heading">
          Building Sydney's<br />developer<br />community.
        </h1>
        <p class="hero-body">
          A vibrant hub for tech innovators, exploring the future of Google
          technologies and beyond, together.
        </p>
        <div class="hero-actions">
          <a
            href="https://gdg.community.dev/gdg-sydney/"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary btn-lg"
          >
            Join the community
          </a>
          <a href="/speak" class="hero-speak-link">
            Speak at a meetup →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════ UPCOMING EVENTS ══════════════════════════ -->
  {upcomingEvents.length > 0 && (
    <section class="section section-events" id="events" aria-labelledby="events-heading">
      <div class="container">
        <h2 class="section-title" id="events-heading">Upcoming events</h2>
        <div class="events-grid">
          {upcomingEvents.map(event => {
            const { label, accent } = classifyEvent(event);
            return (
              <div class={`event-card event-card--${accent}`}>
                <div class="event-card-accent" aria-hidden="true"></div>
                <div class="event-card-body">
                  <div class="event-card-top">
                    <span class="event-tag">{label}</span>
                    <div class="event-meta">
                      <span class="event-date">{formatEventDate(event.start_date)}</span>
                      <span class="event-time">{formatEventTime(event.start_date)}</span>
                    </div>
                  </div>
                  <h3 class="event-title">{event.title}</h3>
                  {event.description_short && (
                    <p class="event-desc">{event.description_short}</p>
                  )}
                  <a href={event.url} target="_blank" rel="noopener noreferrer" class="event-rsvp">
                    RSVP
                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" width="13" height="13" aria-hidden="true">
                      <path d="M2.5 8h11M9 3.5 13.5 8 9 12.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ══════════════════════════════ ABOUT ═════════════════════════════════ -->
  <section class="section" id="about" aria-labelledby="about-heading">
    <div class="container">
      <div class="about-wrap">
        <div class="about-body">
          <h2 class="section-title" id="about-heading">About GDG Sydney</h2>
          <div class="about-text-group">
            <p>
              GDG Sydney is a vibrant hub for tech innovators, where the future of
              Google technologies and beyond is explored. With over {memberCount} members, we
              bring together developers, designers, and tech enthusiasts from across
              the city to connect, learn, and grow.
            </p>
            <p>
              We focus on AI &amp; Machine Learning, Google Cloud &amp; Infrastructure,
              multi-platform development, and career growth. We host regular meetups
              at Google Sydney, Mantel Group, and other hubs across the city.
              All experience levels welcome.
            </p>
          </div>
          <div class="about-links">
            <a
              href="https://gdg.community.dev/gdg-sydney/"
              target="_blank"
              rel="noopener noreferrer"
              class="about-link about-link-primary"
            >
              Visit the GDG Sydney community page
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14" aria-hidden="true">
                <path d="M2.5 8h11M9 3.5 13.5 8 9 12.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a
              href="https://developers.google.com/community/gdg"
              target="_blank"
              rel="noopener noreferrer"
              class="about-link"
            >
              Learn about the global GDG programme
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14" aria-hidden="true">
                <path d="M2.5 8h11M9 3.5 13.5 8 9 12.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════ STATS ══════════════════════════════════ -->
  <section class="section-stats" aria-label="Community stats">
    <div class="container">
      <div class="stats-grid">
        <div class="stat">
          <span class="stat-num">{memberCount}</span>
          <span class="stat-label">Members</span>
        </div>
        <div class="stat">
          <span class="stat-num">{totalEventCount}</span>
          <span class="stat-label">Events run</span>
        </div>
        <div class="stat">
          <span class="stat-num">{new Date().getFullYear() - 2013}</span>
          <span class="stat-label">Years active</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════ PAST EVENTS ══════════════════════════════ -->
  <section class="section section-past" id="past-events" aria-labelledby="past-heading">
    <div class="container">
      <h2 class="section-title" id="past-heading">Past events</h2>
      <div class="past-list">
        {pastEvents.map(event => {
          const { label, accent } = classifyEvent(event as BevyEvent);
          return (
            <a href={event.url} target="_blank" rel="noopener noreferrer" class="past-item">
              <span class={`past-tag past-tag--${accent}`}>{label}</span>
              <span class="past-title">{event.title}</span>
              <span class="past-date">{formatEventDate(event.start_date)}</span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════ TEAM ═════════════════════════════════ -->
  {team.length > 0 && (
    <section class="section section-team" id="team" aria-labelledby="team-heading">
      <div class="container">
        <h2 class="section-title" id="team-heading">Our team</h2>
        <div class="team-grid">
          {team.map(member => (
            <a
              href={`https://gdg.community.dev${member.user.profile_url}`}
              target="_blank"
              rel="noopener noreferrer"
              class="team-card"
            >
              <img
                src={member.user.avatar.thumbnail_url}
                alt={member.user.full_name}
                class="team-avatar"
                loading="lazy"
              />
              <div class="team-info">
                <p class="team-name">{member.user.full_name}</p>
                {(member.user.title || member.user.company) && (
                  <p class="team-role">
                    {member.user.title}{member.user.title && member.user.company ? ', ' : ''}{member.user.company}
                  </p>
                )}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ══════════════════════════ COMMUNITY LINKS ═══════════════════════════ -->
  <section class="section-community" id="community" aria-label="Find us online">
    <div class="container">
      <p class="community-label">Find us online</p>
      <nav class="community-links-big">
        <a href="https://www.meetup.com/gdgcloudsydney/" target="_blank" rel="noopener noreferrer" class="big-link" data-accent="meetup">
          <span>Meetup</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28" aria-hidden="true"><path d="M7 17 17 7M7 7h10v10" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="https://www.linkedin.com/company/gdg-sydney/" target="_blank" rel="noopener noreferrer" class="big-link" data-accent="linkedin">
          <span>LinkedIn</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28" aria-hidden="true"><path d="M7 17 17 7M7 7h10v10" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="https://www.instagram.com/gdgsydney" target="_blank" rel="noopener noreferrer" class="big-link" data-accent="instagram">
          <span>Instagram</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28" aria-hidden="true"><path d="M7 17 17 7M7 7h10v10" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </nav>
    </div>
  </section>

  <!-- ══════════════════════════════ PARTNERS ═════════════════════════════ -->
  {partners.length > 0 && (
    <section class="section section-partners" id="partners" aria-labelledby="partners-heading">
      <div class="container">
        <h2 class="section-title" id="partners-heading">Partners</h2>
        <div class="partners-grid">
          {partners.map(partner => (
            <a
              href={partner.url}
              target="_blank"
              rel="noopener noreferrer"
              class="partner-card"
              aria-label={partner.company}
            >
              <img src={partner.logo} alt={partner.company} class="partner-logo" loading="lazy" />
            </a>
          ))}
        </div>
      </div>
    </section>
  )}


  <!-- ════════════════════════════════ CTA ════════════════════════════════ -->
  <section class="section section-cta" aria-label="Join the community">
    <div class="container cta-inner">
      <div class="cta-text">
        <h2 class="cta-heading">Come build with us.</h2>
        <p class="cta-sub">Free events, real talks, and a community of developers across Sydney.</p>
      </div>
      <a href="https://gdg.community.dev/gdg-sydney/" target="_blank" rel="noopener noreferrer" class="btn-cta-join">
        Join the community
      </a>
    </div>
  </section>

  <!-- ══════════════════════════════ FOOTER ════════════════════════════════ -->
  <footer class="footer" aria-label="Site footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <div class="footer-logo">
          <img src="/logo.png" alt="" class="logo-img logo-img-footer" aria-hidden="true" />
          <span class="footer-wordmark">GDG Sydney</span>
        </div>
        <p class="footer-tagline">Part of the global Google Developer Groups network</p>
      </div>
      <nav class="footer-links" aria-label="Footer links">
        <a href="mailto:hello@gdgsydney.com" class="footer-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="15" height="15" aria-hidden="true">
            <path d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          hello@gdgsydney.com
        </a>
        <a href="/code-of-conduct" class="footer-link">Code of Conduct</a>
        <div class="footer-socials">
          <a href="https://www.meetup.com/gdgcloudsydney/" target="_blank" rel="noopener noreferrer" class="footer-social-link" aria-label="Meetup">
            <!-- Meetup icon -->
