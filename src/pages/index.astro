          </a>
        </div>
      </nav>
    </div>
    <div class="footer-base">
      <div class="container">
        <p class="footer-legal">
          © {new Date().getFullYear()} GDG Sydney. GDG Sydney is an independently-run community group
          and is not an official Google product or service.
        </p>
      </div>
    </div>
  </footer>

</body>
</html>

<style is:global>
  /* ─── Reset & Base ──────────────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  :root {
    --blue:   #4285F4;
    --green:  #34A853;
    --yellow: #f9ab00;
    --red:    #EA4335;

    --bg:     #f5f4f0;
    --dark:   #1e1e1e;
    --text:   #2a2a2a;
    --muted:  #6b7280;
    --white:  #ffffff;
    --border: rgba(0, 0, 0, 0.09);

    --sans: 'Google Sans', system-ui, -apple-system, sans-serif;
    --mono: 'JetBrains Mono', 'Roboto Mono', monospace;

    --header-h: 68px;
    --radius-card: 16px;
  }

  body {
    font-family: var(--sans);
    background: var(--bg);
    color: var(--text);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }

  /* ─── Layout ────────────────────────────────────────────────────────── */
  .container {
    max-width: 1160px;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 3rem);
  }

  /* ─── Logo Dots ─────────────────────────────────────────────────────── */
  .logo-dots {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3px;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .dot {
    display: block;
    border-radius: 50%;
  }

  .dot-blue   { background: var(--blue); }
  .dot-red    { background: var(--red); }
  .dot-yellow { background: var(--yellow); }
  .dot-green  { background: var(--green); }

  /* ─── Header ────────────────────────────────────────────────────────── */
  .header {
    position: fixed;
    inset-inline: 0;
    top: 0;
    height: var(--header-h);
    background: rgba(245, 244, 240, 0.85);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border-bottom: 1px solid var(--border);
    z-index: 100;
    display: flex;
    align-items: center;
  }

