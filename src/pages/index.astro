---
import '../styles/global.css';
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <meta name="description" content="GDG Sydney — Google Developer Group Sydney. Connecting developers, designers, and tech enthusiasts across the city." />
  <title>GDG Sydney — Google Developer Group</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- ═══════════════════════════════ HEADER ═══════════════════════════════ -->
  <header class="header">
    <div class="container header-inner">
      <a href="/" class="logo" aria-label="GDG Sydney home">
        <div class="logo-dots" aria-hidden="true">
          <span class="dot dot-blue"></span>
          <span class="dot dot-red"></span>
          <span class="dot dot-yellow"></span>
          <span class="dot dot-green"></span>
        </div>
        <span class="logo-wordmark">GDG Sydney</span>
      </a>
      <nav class="header-nav" aria-label="Main navigation">
        <a href="#community" class="nav-link">Community</a>
        <a href="#about" class="nav-link">About</a>
        <a
          href="https://www.meetup.com/gdg-sydney/"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary btn-sm"
        >
          Join on Meetup
        </a>
      </nav>
    </div>
  </header>

  <!-- ════════════════════════════════ HERO ════════════════════════════════ -->
  <section class="hero" id="home" aria-labelledby="hero-heading">
    <div class="hero-geo" aria-hidden="true">
      <div class="geo-quad">
        <div class="geo-blue"></div>
        <div class="geo-red"></div>
        <div class="geo-yellow"></div>
        <div class="geo-green"></div>
      </div>
    </div>

    <div class="container">
      <div class="hero-content">
        <div class="hero-eyebrow">
          <span class="eyebrow-dot" aria-hidden="true"></span>
          Google Developer Group Sydney
        </div>
        <h1 class="hero-heading" id="hero-heading">
          Building Sydney's<br />developer<br />community.
        </h1>
        <p class="hero-body">
          GDG Sydney is an open community for developers, designers, and tech
          enthusiasts who want to connect, grow their skills, and build together.
          All are welcome — come as you are.
        </p>
        <div class="hero-actions">
          <a
            href="https://www.meetup.com/gdg-sydney/"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary btn-lg"
          >
            See upcoming events →
          </a>
          <a href="#about" class="btn btn-ghost btn-lg">Learn more</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════ COMMUNITY LINKS ═══════════════════════════ -->
  <section class="section bg-white" id="community" aria-labelledby="community-heading">
    <div class="container">
      <header class="section-header">
        <p class="section-eyebrow">Stay connected</p>
        <h2 class="section-title" id="community-heading">Find us everywhere</h2>
      </header>

      <div class="community-list" role="list">

        <a href="#" target="_blank" rel="noopener noreferrer"
           class="community-item" data-accent="blue" role="listitem"
           aria-label="Join GDG Sydney on Discord">
          <div class="ci-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
              <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057.1 18.082.114 18.105.134 18.12a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
            </svg>
          </div>
          <div class="ci-body">
            <span class="ci-name">Discord</span>
            <span class="ci-desc">Chat with the community in real time</span>
          </div>
          <span class="ci-arrow" aria-hidden="true">→</span>
        </a>

        <a href="https://www.meetup.com/gdg-sydney/" target="_blank" rel="noopener noreferrer"
           class="community-item" data-accent="green" role="listitem"
           aria-label="Join GDG Sydney on Meetup">
          <div class="ci-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="22" height="22">
              <path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="ci-body">
            <span class="ci-name">Meetup</span>
            <span class="ci-desc">RSVP for upcoming events and meetups</span>
          </div>
          <span class="ci-arrow" aria-hidden="true">→</span>
        </a>

        <a href="#" target="_blank" rel="noopener noreferrer"
           class="community-item" data-accent="yellow" role="listitem"
           aria-label="Follow GDG Sydney on LinkedIn">
          <div class="ci-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </div>
          <div class="ci-body">
            <span class="ci-name">LinkedIn</span>
            <span class="ci-desc">Professional updates and community news</span>
          </div>
          <span class="ci-arrow" aria-hidden="true">→</span>
        </a>

        <a href="#" target="_blank" rel="noopener noreferrer"
           class="community-item" data-accent="red" role="listitem"
           aria-label="Follow GDG Sydney on Instagram">
          <div class="ci-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
            </svg>
          </div>
          <div class="ci-body">
            <span class="ci-name">Instagram</span>
            <span class="ci-desc">Behind-the-scenes moments and event highlights</span>
          </div>
          <span class="ci-arrow" aria-hidden="true">→</span>
        </a>

        <a href="#" target="_blank" rel="noopener noreferrer"
           class="community-item" data-accent="blue" role="listitem"
           aria-label="Watch GDG Sydney on YouTube">
          <div class="ci-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </div>
          <div class="ci-body">
            <span class="ci-name">YouTube</span>
            <span class="ci-desc">Watch talks, workshops, and event recaps</span>
          </div>
          <span class="ci-arrow" aria-hidden="true">→</span>
        </a>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════ ABOUT ═════════════════════════════════ -->
  <section class="section" id="about" aria-labelledby="about-heading">
    <div class="container">
      <div class="about-wrap">
        <div class="about-decoration" aria-hidden="true">
          <div class="about-geo">
            <span class="ag ag-blue"></span>
            <span class="ag ag-red"></span>
            <span class="ag ag-yellow"></span>
            <span class="ag ag-green"></span>
          </div>
        </div>
        <div class="about-body">
          <p class="section-eyebrow">Who we are</p>
          <h2 class="section-title" id="about-heading">About GDG Sydney</h2>
          <div class="about-text-group">
            <p>
              Google Developer Groups (GDG) are community-led groups for developers
              interested in Google's technologies. GDG Sydney brings together curious,
              creative people from across the city to learn, share knowledge, and build
              meaningful connections.
            </p>
            <p>
              We host regular meetups, workshops, and hands-on sessions — from Android
              and Flutter to web, cloud, AI, and everything in between. Beginners and
              experts are equally welcome.
            </p>
          </div>
          <a
            href="https://developers.google.com/community/gdg"
            target="_blank"
            rel="noopener noreferrer"
            class="about-link"
          >
            Learn about the global GDG programme
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14" aria-hidden="true">
              <path d="M2.5 8h11M9 3.5 13.5 8 9 12.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════ FOOTER ════════════════════════════════ -->
  <footer class="footer" aria-label="Site footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <div class="footer-logo">
          <div class="logo-dots" aria-hidden="true">
            <span class="dot dot-blue"></span>
            <span class="dot dot-red"></span>
            <span class="dot dot-yellow"></span>
            <span class="dot dot-green"></span>
          </div>
          <span class="footer-wordmark">GDG Sydney</span>
        </div>
        <p class="footer-tagline">Part of the global Google Developer Groups network</p>
      </div>
      <nav class="footer-links" aria-label="Footer links">
        <a href="mailto:gdg.sydney@gmail.com" class="footer-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="15" height="15" aria-hidden="true">
            <path d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          gdg.sydney@gmail.com
        </a>
        <a
          href="https://developers.google.com/community/gdg/code-of-conduct"
          target="_blank"
          rel="noopener noreferrer"
          class="footer-link"
        >
          Code of Conduct
        </a>
      </nav>
    </div>
    <div class="footer-base">
      <div class="container">
        <p class="footer-legal">
          © {new Date().getFullYear()} GDG Sydney. GDG Sydney is an independently-run community group
          and is not an official Google product or service.
        </p>
      </div>
    </div>
  </footer>

</body>
</html>

<style is:global>
  /* ─── Reset & Base ──────────────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  :root {
    --blue:   #4285F4;
    --green:  #34A853;
    --yellow: #f9ab00;
    --red:    #EA4335;

    --bg:     #f5f4f0;
    --dark:   #1e1e1e;
    --text:   #2a2a2a;
    --muted:  #6b7280;
    --white:  #ffffff;
    --border: rgba(0, 0, 0, 0.09);

    --sans: 'Google Sans', system-ui, -apple-system, sans-serif;
    --mono: 'JetBrains Mono', 'Roboto Mono', monospace;

    --header-h: 68px;
    --radius-card: 16px;
  }

  body {
    font-family: var(--sans);
    background: var(--bg);
    color: var(--text);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }

  /* ─── Layout ────────────────────────────────────────────────────────── */
  .container {
    max-width: 1160px;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 3rem);
  }

  /* ─── Logo Dots ─────────────────────────────────────────────────────── */
  .logo-dots {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3px;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .dot {
    display: block;
    border-radius: 50%;
  }

  .dot-blue   { background: var(--blue); }
  .dot-red    { background: var(--red); }
  .dot-yellow { background: var(--yellow); }
  .dot-green  { background: var(--green); }

  /* ─── Header ────────────────────────────────────────────────────────── */
  .header {
    position: fixed;
    inset-inline: 0;
    top: 0;
    height: var(--header-h);
    background: rgba(245, 244, 240, 0.85);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border-bottom: 1px solid var(--border);
    z-index: 100;
    display: flex;
    align-items: center;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 9px;
    text-decoration: none;
    color: var(--dark);
  }

  .logo-wordmark {
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--dark);
  }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .nav-link:hover { color: var(--dark); }

  /* ─── Buttons ───────────────────────────────────────────────────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    border-radius: 100px;
    font-family: var(--sans);
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease, border-color 0.15s ease;
    cursor: pointer;
    border: none;
    line-height: 1;
  }
  .btn:hover  { transform: translateY(-1px); }
  .btn:active { transform: translateY(0); }

  .btn-sm  { padding: 0.48em 1.1em;  font-size: 0.825rem; }
  .btn-lg  { padding: 0.78em 1.8em;  font-size: 1rem; }

  .btn-primary {
    background: var(--blue);
    color: white;
    box-shadow: 0 1px 6px rgba(66, 133, 244, 0.28);
  }
  .btn-primary:hover {
    box-shadow: 0 4px 18px rgba(66, 133, 244, 0.42);
  }

  .btn-ghost {
    background: transparent;
    color: var(--dark);
    border: 1.5px solid rgba(0, 0, 0, 0.2);
  }
  .btn-ghost:hover {
    border-color: var(--dark);
    background: rgba(0, 0, 0, 0.04);
  }

  /* ─── Hero ──────────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-top: var(--header-h);
    overflow: hidden;
  }

  .hero-geo {
    position: absolute;
    bottom: -110px;
    right: -90px;
    width: 400px;
    height: 400px;
    transform: rotate(18deg);
    border-radius: 44px;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
    opacity: 0.82;
    animation: geoIn 1.2s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 0.5s;
  }

  .geo-quad {
    display: grid;
    grid-template-columns: 1fr 1fr;
    width: 100%;
    height: 100%;
  }

  .geo-blue   { background: var(--blue); }
  .geo-red    { background: var(--red); }
  .geo-yellow { background: var(--yellow); }
  .geo-green  { background: var(--green); }

  .hero .container {
    position: relative;
    z-index: 1;
    padding-top: 5.5rem;
    padding-bottom: 6rem;
  }

  .hero-content {
    max-width: 640px;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--mono);
    font-size: 0.68rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    margin-bottom: 1.6rem;
    animation: fadeUp 0.65s ease both;
    animation-delay: 0.05s;
  }

  .eyebrow-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--green);
    flex-shrink: 0;
    animation: pulse 2.5s ease infinite;
  }

  .hero-heading {
    font-size: clamp(3rem, 7.5vw, 6rem);
    font-weight: 800;
    line-height: 1.0;
    letter-spacing: -0.04em;
    color: var(--dark);
    margin-bottom: 1.5rem;
    animation: fadeUp 0.65s ease both;
    animation-delay: 0.15s;
  }

  .hero-body {
    font-size: clamp(1rem, 1.6vw, 1.125rem);
    line-height: 1.72;
    color: var(--muted);
    margin-bottom: 2.5rem;
    max-width: 480px;
    font-weight: 400;
    animation: fadeUp 0.65s ease both;
    animation-delay: 0.28s;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.875rem;
    animation: fadeUp 0.65s ease both;
    animation-delay: 0.42s;
  }

  /* ─── Keyframes ─────────────────────────────────────────────────────── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(22px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes geoIn {
    from { opacity: 0; transform: rotate(18deg) scale(0.7) translate(40px, 40px); }
    to   { opacity: 0.82; transform: rotate(18deg) scale(1) translate(0, 0); }
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.35; }
  }

  /* ─── Sections ──────────────────────────────────────────────────────── */
  .section {
    padding-block: clamp(4.5rem, 8vw, 7rem);
  }

  .bg-white { background: var(--white); }

  .section-eyebrow {
    font-family: var(--mono);
    font-size: 0.68rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--blue);
    margin-bottom: 0.6rem;
  }

  .section-header {
    margin-bottom: 2.75rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--dark);
    line-height: 1.1;
  }

  /* ─── Community List ────────────────────────────────────────────────── */
  .community-list {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    overflow: hidden;
  }

  .community-item {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.4rem 1.75rem;
    background: var(--white);
