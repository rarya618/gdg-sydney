---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import UpcomingEvents from '../components/UpcomingEvents';
import AboutStats from '../components/AboutStats';
import PastEvents from '../components/PastEvents';
import Team from '../components/Team';
import Partners from '../components/Partners';
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <meta name="description" content="GDG Sydney, Google Developer Group Sydney. Connecting developers, designers, and tech enthusiasts across the city." />
  <title>GDG Sydney | Google Developer Group</title>
  <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />
  <meta property="og:site_name" content="GDG Sydney" />
  <meta property="og:title" content="GDG Sydney | Google Developer Group" />
  <meta property="og:description" content="A vibrant hub for tech innovators in Sydney. 2,000+ developers, designers, and tech enthusiasts connecting, learning, and growing together." />
  <meta property="og:image" content={new URL('/operaHouse.png', Astro.site)} />
  <meta property="og:image:alt" content="Sydney Opera House illustration" />
  <meta property="og:locale" content="en_AU" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="GDG Sydney | Google Developer Group" />
  <meta name="twitter:description" content="A vibrant hub for tech innovators in Sydney. 2,000+ developers, designers, and tech enthusiasts connecting, learning, and growing together." />
  <meta name="twitter:image" content={new URL('/operaHouse.png', Astro.site)} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- ═══════════════════════════════ HEADER ═══════════════════════════════ -->
  <header class="header">
    <div class="container header-inner">
      <a href="/" class="logo" aria-label="GDG Sydney home">
        <img src="/logo.png" alt="" class="logo-img" aria-hidden="true" />
        <span class="logo-wordmark">GDG Sydney</span>
      </a>
      <nav class="header-nav" aria-label="Main navigation">
        <a href="#events" class="nav-link">Events</a>
        <a href="/speak" class="nav-link">Speak</a>
        <a href="https://devfest.gdgsydney.com?utm_source=gdgsydney&utm_medium=nav&utm_campaign=launch" target="_blank" rel="noopener noreferrer" class="nav-link">DevFest</a>
        <a
          href="https://gdg.community.dev/gdg-sydney/"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary btn-sm"
        >
          Join the community
        </a>
      </nav>
    </div>
  </header>

  <!-- ═══════════════════════════════ BANNER ═══════════════════════════════ -->
  <a href="https://devfest.gdgsydney.com/call-for-speakers?utm_source=gdgsydney&utm_medium=banner&utm_campaign=launch" target="_blank" rel="noopener noreferrer" class="cfp-banner">
    <div class="container cfp-banner-inner">
      <span class="cfp-banner-text">
        <strong>Call for speakers is open</strong> for DevFest Sydney.
      </span>
      <span class="cfp-banner-cta">Submit a session</span>
    </div>
  </a>

  <!-- ════════════════════════════════ HERO ════════════════════════════════ -->
  <section class="hero" id="home" aria-labelledby="hero-heading">
    <div class="hero-illustration" aria-hidden="true">
      <img src="/operaHouse.png" alt="" aria-hidden="true" />
    </div>

    <div class="container">
      <div class="hero-content">
        <h1 class="hero-heading" id="hero-heading">
          Building Sydney's<br />developer<br />community.
        </h1>
        <p class="hero-body">
          A vibrant hub for tech innovators, exploring the future of Google
          technologies and beyond, together.
        </p>
        <div class="hero-actions">
          <a
            href="https://gdg.community.dev/gdg-sydney/"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary btn-lg"
          >
            Join the community
          </a>
          <a href="/speak" class="hero-speak-link">
            Speak at a meetup →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════ UPCOMING EVENTS ══════════════════════════ -->
  <UpcomingEvents client:load />

  <!-- ══════════════════════════ ABOUT + STATS ═════════════════════════════ -->
  <AboutStats client:load />

  <!-- ══════════════════════════ PAST EVENTS ══════════════════════════════ -->
  <PastEvents client:load />

  <!-- ══════════════════════════════ TEAM ═════════════════════════════════ -->
  <Team client:load />

  <!-- ══════════════════════════ COMMUNITY LINKS ═══════════════════════════ -->
  <section class="section-community" id="community" aria-label="Find us online">
    <div class="container">
      <p class="community-label">Find us online</p>
      <nav class="community-links-big">
        <a href="https://www.meetup.com/gdgcloudsydney/" target="_blank" rel="noopener noreferrer" class="big-link" data-accent="meetup">
          <span>Meetup</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28" aria-hidden="true"><path d="M7 17 17 7M7 7h10v10" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="https://www.linkedin.com/company/gdg-sydney/" target="_blank" rel="noopener noreferrer" class="big-link" data-accent="linkedin">
          <span>LinkedIn</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28" aria-hidden="true"><path d="M7 17 17 7M7 7h10v10" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="https://www.instagram.com/gdgsydney" target="_blank" rel="noopener noreferrer" class="big-link" data-accent="instagram">
          <span>Instagram</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28" aria-hidden="true"><path d="M7 17 17 7M7 7h10v10" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </nav>
    </div>
  </section>

  <!-- ══════════════════════════════ PARTNERS ═════════════════════════════ -->
  <Partners client:load />


  <!-- ════════════════════════════════ CTA ════════════════════════════════ -->
  <section class="section section-cta" aria-label="Join the community">
    <div class="container cta-inner">
      <div class="cta-text">
        <h2 class="cta-heading">Come build with us.</h2>
        <p class="cta-sub">Free events, real talks, and a community of developers across Sydney.</p>
      </div>
      <a href="https://gdg.community.dev/gdg-sydney/" target="_blank" rel="noopener noreferrer" class="btn-cta-join">
        Join the community
      </a>
    </div>
  </section>

  <!-- ══════════════════════════════ FOOTER ════════════════════════════════ -->
  <Footer />

</body>
</html>

<style is:global>
  /* ─── Reset & Base ──────────────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  :root {
    --blue:   #4285F4;
    --green:  #34A853;
    --yellow: #f9ab00;
    --red:    #EA4335;

    --bg:     #f5f4f0;
    --dark:   #1e1e1e;
    --text:   #2a2a2a;
    --muted:  #6b7280;
    --white:  #ffffff;
    --border: rgba(0, 0, 0, 0.09);

    --sans: 'Google Sans', system-ui, -apple-system, sans-serif;
    --mono: 'JetBrains Mono', 'Roboto Mono', monospace;

    --header-h: 68px;
    --radius-card: 16px;
  }

  body {
    font-family: var(--sans);
    background: var(--bg);
    color: var(--text);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }

  /* ─── Layout ────────────────────────────────────────────────────────── */
  .container {
    max-width: 1160px;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 3rem);
  }

  /* ─── Logo Dots ─────────────────────────────────────────────────────── */
  .logo-dots {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3px;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .dot {
    display: block;
    border-radius: 50%;
  }

  .dot-blue   { background: var(--blue); }
  .dot-red    { background: var(--red); }
  .dot-yellow { background: var(--yellow); }
  .dot-green  { background: var(--green); }

  /* ─── Header ────────────────────────────────────────────────────────── */
  .header {
    position: fixed;
    inset-inline: 0;
    top: 0;
    height: var(--header-h);
    background: rgba(245, 244, 240, 0.85);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border-bottom: 1px solid var(--border);
    z-index: 100;
    display: flex;
    align-items: center;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 2px;
    text-decoration: none;
    color: var(--dark);
  }

  .logo-img {
    height: 28px;
    width: auto;
    display: block;
    flex-shrink: 0;
  }

  .logo-img-footer {
    height: 26px;
  }

  .logo-wordmark {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--dark);
  }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .nav-link:hover { color: var(--dark); }

  /* ─── Buttons ───────────────────────────────────────────────────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    border-radius: 100px;
    font-family: var(--sans);
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease, border-color 0.15s ease;
    cursor: pointer;
    border: none;
    line-height: 1;
  }
  .btn:hover  { transform: translateY(-1px); }
  .btn:active { transform: translateY(0); }

  .btn-sm  { padding: 0.6em 1.4em;  font-size: 0.825rem; }
  .btn-lg  { padding: 0.78em 1.8em;  font-size: 1rem; }

  .btn-primary {
    background: var(--blue);
    color: white;
    box-shadow: 0 1px 6px rgba(66, 133, 244, 0.28);
  }
  .btn-primary:hover {
    box-shadow: 0 4px 18px rgba(66, 133, 244, 0.42);
  }

  .btn-ghost {
    background: transparent;
    color: var(--dark);
    border: 1.5px solid rgba(0, 0, 0, 0.2);
  }
  .btn-ghost:hover {
    border-color: var(--dark);
    background: rgba(0, 0, 0, 0.04);
  }

  /* ─── CFP Banner ────────────────────────────────────────────────────── */
  .cfp-banner {
    display: block;
    background: var(--blue);
    color: var(--white);
    text-decoration: none;
    margin-top: var(--header-h);
  }
  .cfp-banner-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    padding-block: 0.65rem;
    text-align: center;
  }
  .cfp-banner-text {
    font-size: 0.9rem;
  }
  .cfp-banner-text strong {
    font-family: var(--sans);
    font-weight: 700;
  }
  .cfp-banner-cta {
    font-family: var(--sans);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--white);
    text-decoration: underline;
    text-underline-offset: 3px;
    white-space: nowrap;
  }

  /* ─── Hero ──────────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-illustration {
    position: absolute;
    right: clamp(-660px, -40vw, -260px);
    bottom: 0;
    width: clamp(800px, 95vw, 1400px);
    pointer-events: none;
    z-index: 0;
    animation: fadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 0.45s;
  }

  .hero-illustration svg,
  .hero-illustration img {
    width: 100%;
    height: auto;
    display: block;
  }

  .hero .container {
    position: relative;
    z-index: 1;
    padding-top: 5.5rem;
    padding-bottom: 6rem;
  }

  .hero-content {
    max-width: 640px;
  }

  .hero-heading {
    font-size: clamp(3rem, 7.5vw, 6rem);
    font-weight: 800;
    line-height: 1.0;
    letter-spacing: -0.04em;
    color: var(--dark);
    margin-bottom: 1.5rem;
    animation: fadeUp 0.65s ease both;
    animation-delay: 0.1s;
  }

  .hero-body {
    font-size: clamp(1rem, 1.6vw, 1.125rem);
    line-height: 1.72;
    color: var(--muted);
    margin-bottom: 2.5rem;
    max-width: 480px;
    font-weight: 400;
    animation: fadeUp 0.65s ease both;
    animation-delay: 0.25s;
  }

  .hero .btn {
    animation: fadeUp 0.65s ease both;
    animation-delay: 0.4s;
  }

  /* ─── Keyframes ─────────────────────────────────────────────────────── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(22px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ─── Sections ──────────────────────────────────────────────────────── */
  .section {
    padding-block: clamp(4.5rem, 8vw, 7rem);
  }

  .section-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--dark);
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  /* ─── Community (dark typographic) ──────────────────────────────────── */
  .section-community {
    background: var(--dark);
    padding-block: clamp(3.5rem, 6vw, 5.5rem);
  }

  .community-label {
    font-family: var(--sans);
    font-size: 0.68rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.3);
    margin-bottom: 1.5rem;
  }

  .community-links-big {
    display: flex;
    flex-direction: column;
  }

  .big-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 1.1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    text-decoration: none;
    color: white;
    font-size: clamp(2rem, 5vw, 3.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    transition: color 0.2s ease;
  }

  .big-link:last-child { border-bottom: 1px solid rgba(255, 255, 255, 0.1); }

  .big-link svg {
    flex-shrink: 0;
    opacity: 0;
    transform: translate(-6px, 6px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .big-link:hover svg { opacity: 1; transform: translate(0, 0); }
  .big-link[data-accent="meetup"]:hover   { color: #E51937; }
  .big-link[data-accent="linkedin"]:hover { color: #0A66C2; }
  .big-link[data-accent="instagram"]:hover span {
    background: linear-gradient(90deg, #F58529, #DD2A7B, #8134AF);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .big-link[data-accent="instagram"]:hover svg { color: #DD2A7B; }

  /* ─── About ─────────────────────────────────────────────────────────── */
  .about-wrap {
    max-width: 720px;
  }

  .about-body .section-title {
    margin-bottom: 1.5rem;
  }

  .about-text-group {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .about-text-group p {
    font-size: 1.05rem;
    line-height: 1.78;
    color: #4a4a4a;
    font-weight: 400;
  }

  .about-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .about-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--muted);
    text-decoration: none;
    transition: gap 0.2s ease, color 0.15s ease;
  }

  .about-link:hover { gap: 0.7rem; color: var(--dark); }

  .about-link-primary {
    color: var(--blue);
  }

  .about-link-primary:hover { color: var(--blue); }

  .hero-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }

  .hero-speak-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--dark);
    text-decoration: none;
    transition: color 0.15s ease, gap 0.15s ease;
  }

  .hero-speak-link:hover { color: var(--blue); }

  /* ─── CTA ───────────────────────────────────────────────────────────── */
  .section-cta {
    background: var(--blue);
    padding-block: clamp(3rem, 5vw, 4.5rem);
  }

  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .cta-heading {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: white;
    margin-bottom: 0.5rem;
  }

  .cta-sub {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.75);
    max-width: 42ch;
  }

  .btn-cta-join {
    display: inline-flex;
    align-items: center;
    padding: 0.85em 2em;
    border-radius: 100px;
    background: white;
    color: var(--blue);
    font-size: 0.95rem;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: opacity 0.15s ease;
  }

  .btn-cta-join:hover { opacity: 0.9; }

  /* ─── Events ───────────────────────────────────────────────────────── */
  .section-events {
    background: var(--bg);
  }

  .events-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.5rem;
  }

  .event-card {
    background: var(--white);
    border-radius: var(--radius-card);
    border: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }

  .event-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.1);
  }

  .event-card-accent {
    height: 4px;
    width: 100%;
  }

  .event-card--blue .event-card-accent { background: var(--blue); }
  .event-card--green .event-card-accent { background: var(--green); }
  .event-card--yellow .event-card-accent { background: var(--yellow); }

  .event-card-body {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0;
  }

  .event-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 1.1rem;
  }

  .event-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    font-size: 0.78rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .event-tag::before {
    content: '';
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .event-card--blue .event-tag { color: var(--blue); }
  .event-card--blue .event-tag::before { background: var(--blue); }
  .event-card--green .event-tag { color: var(--green); }
  .event-card--green .event-tag::before { background: var(--green); }
  .event-card--yellow .event-tag { color: #c47f00; }
  .event-card--yellow .event-tag::before { background: var(--yellow); }

  .event-meta {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    margin-left: auto;
    flex-shrink: 0;
  }

  .event-date {
    font-family: var(--sans);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--muted);
  }

  .event-time {
    font-family: var(--sans);
    font-size: 0.8rem;
    color: var(--muted);
    opacity: 0.65;
  }

  .event-time::before {
    content: '·';
    margin-right: 0.35rem;
  }

  .event-title {
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--dark);
    line-height: 1.25;
    margin-bottom: 0.75rem;
  }

  .event-desc {
    font-size: 0.83rem;
    color: var(--muted);
    line-height: 1.65;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 1.5rem;
    flex: 1;
  }

  .event-rsvp {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    align-self: flex-start;
    padding: 0.6em 1.4em;
    border-radius: 100px;
    font-size: 0.83rem;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .event-card--blue .event-rsvp {
    background: var(--blue);
    color: white;
    box-shadow: 0 1px 6px rgba(66, 133, 244, 0.28);
  }
  .event-card--blue .event-rsvp:hover {
    box-shadow: 0 4px 18px rgba(66, 133, 244, 0.42);
    transform: translateY(-1px);
  }

