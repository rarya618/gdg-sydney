---
import '../styles/global.css';
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <meta name="description" content="GDG Sydney, Google Developer Group Sydney. Connecting developers, designers, and tech enthusiasts across the city." />
  <title>GDG Sydney | Google Developer Group</title>
  <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />
  <meta property="og:site_name" content="GDG Sydney" />
  <meta property="og:title" content="GDG Sydney | Google Developer Group" />
  <meta property="og:description" content="A vibrant hub for tech innovators in Sydney. 2,000+ developers, designers, and tech enthusiasts connecting, learning, and growing together." />
  <meta property="og:image" content={new URL('/operaHouse.png', Astro.site)} />
  <meta property="og:image:alt" content="Sydney Opera House illustration" />
  <meta property="og:locale" content="en_AU" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="GDG Sydney | Google Developer Group" />
  <meta name="twitter:description" content="A vibrant hub for tech innovators in Sydney. 2,000+ developers, designers, and tech enthusiasts connecting, learning, and growing together." />
  <meta name="twitter:image" content={new URL('/operaHouse.png', Astro.site)} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- ═══════════════════════════════ HEADER ═══════════════════════════════ -->
  <header class="header">
    <div class="container header-inner">
      <a href="/" class="logo" aria-label="GDG Sydney home">
        <img src="/logo.png" alt="" class="logo-img" aria-hidden="true" />
        <span class="logo-wordmark">GDG Sydney</span>
      </a>
      <nav class="header-nav" aria-label="Main navigation">
        <a href="#community" class="nav-link">Community</a>
        <a href="#about" class="nav-link">About</a>
        <a
          href="https://gdg.community.dev/gdg-sydney/"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary btn-sm"
        >
          Join the community
        </a>
      </nav>
    </div>
  </header>

  <!-- ════════════════════════════════ HERO ════════════════════════════════ -->
  <section class="hero" id="home" aria-labelledby="hero-heading">
    <div class="hero-illustration" aria-hidden="true">
      <img src="/operaHouse.png" alt="" aria-hidden="true" />
    </div>

    <div class="container">
      <div class="hero-content">
        <h1 class="hero-heading" id="hero-heading">
          Building Sydney's<br />developer<br />community.
        </h1>
        <p class="hero-body">
          A vibrant hub for tech innovators, exploring the future of Google
          technologies and beyond, together. 2,000+ members across Sydney.
        </p>
        <a
          href="https://gdg.community.dev/gdg-sydney/"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary btn-lg"
        >
          Join the community
        </a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════ COMMUNITY LINKS ═══════════════════════════ -->
  <section class="section-community" id="community" aria-label="Find us online">
    <div class="container">
      <p class="community-label">Find us online</p>
      <nav class="community-links-big">
        <a href="https://www.meetup.com/gdgcloudsydney/" target="_blank" rel="noopener noreferrer"
           class="big-link" data-accent="meetup">
          <span>Meetup</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28" aria-hidden="true">
            <path d="M7 17 17 7M7 7h10v10" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="https://www.linkedin.com/company/gdg-sydney/" target="_blank" rel="noopener noreferrer"
           class="big-link" data-accent="linkedin">
          <span>LinkedIn</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28" aria-hidden="true">
            <path d="M7 17 17 7M7 7h10v10" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="https://www.instagram.com/gdgsydney" target="_blank" rel="noopener noreferrer"
           class="big-link" data-accent="instagram">
          <span>Instagram</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28" aria-hidden="true">
            <path d="M7 17 17 7M7 7h10v10" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </nav>
    </div>
  </section>

  <!-- ══════════════════════════════ ABOUT ═════════════════════════════════ -->
  <section class="section" id="about" aria-labelledby="about-heading">
    <div class="container">
      <div class="about-wrap">
        <div class="about-body">
          <h2 class="section-title" id="about-heading">About GDG Sydney</h2>
          <div class="about-text-group">
            <p>
              GDG Sydney is a vibrant hub for tech innovators, where the future of
              Google technologies and beyond is explored. With over 2,000 members, we
              bring together developers, designers, and tech enthusiasts from across
              the city to connect, learn, and grow.
            </p>
            <p>
              We focus on AI &amp; Machine Learning, Google Cloud &amp; Infrastructure,
              multi-platform development, and career growth. We host regular meetups
              at Google Sydney, Mantel Group, and other hubs across the city.
              All experience levels welcome.
            </p>
          </div>
          <div class="about-links">
            <a
              href="https://gdg.community.dev/gdg-sydney/"
              target="_blank"
              rel="noopener noreferrer"
              class="about-link about-link-primary"
            >
              Visit the GDG Sydney community page
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14" aria-hidden="true">
                <path d="M2.5 8h11M9 3.5 13.5 8 9 12.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a
              href="https://developers.google.com/community/gdg"
              target="_blank"
              rel="noopener noreferrer"
              class="about-link"
            >
              Learn about the global GDG programme
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14" aria-hidden="true">
                <path d="M2.5 8h11M9 3.5 13.5 8 9 12.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════ FOOTER ════════════════════════════════ -->
  <footer class="footer" aria-label="Site footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <div class="footer-logo">
          <img src="/logo.png" alt="" class="logo-img logo-img-footer" aria-hidden="true" />
          <span class="footer-wordmark">GDG Sydney</span>
        </div>
        <p class="footer-tagline">Part of the global Google Developer Groups network</p>
      </div>
      <nav class="footer-links" aria-label="Footer links">
        <a href="mailto:hello@gdgsydney.com" class="footer-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="15" height="15" aria-hidden="true">
            <path d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          hello@gdgsydney.com
        </a>
        <a href="/code-of-conduct" class="footer-link">Code of Conduct</a>
      </nav>
    </div>
    <div class="footer-base">
      <div class="container">
        <p class="footer-legal">
          © {new Date().getFullYear()} GDG Sydney. GDG Sydney is an independently-run community group
          and is not an official Google product or service.
        </p>
      </div>
    </div>
  </footer>

</body>
</html>

<style is:global>
  /* ─── Reset & Base ──────────────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  :root {
    --blue:   #4285F4;
    --green:  #34A853;
    --yellow: #f9ab00;
    --red:    #EA4335;

    --bg:     #f5f4f0;
    --dark:   #1e1e1e;
    --text:   #2a2a2a;
    --muted:  #6b7280;
    --white:  #ffffff;
    --border: rgba(0, 0, 0, 0.09);

    --sans: 'Google Sans', system-ui, -apple-system, sans-serif;
    --mono: 'JetBrains Mono', 'Roboto Mono', monospace;

    --header-h: 68px;
    --radius-card: 16px;
  }

  body {
    font-family: var(--sans);
    background: var(--bg);
    color: var(--text);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }

  /* ─── Layout ────────────────────────────────────────────────────────── */
  .container {
    max-width: 1160px;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 3rem);
  }

  /* ─── Logo Dots ─────────────────────────────────────────────────────── */
  .logo-dots {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3px;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .dot {
    display: block;
    border-radius: 50%;
  }

  .dot-blue   { background: var(--blue); }
  .dot-red    { background: var(--red); }
  .dot-yellow { background: var(--yellow); }
  .dot-green  { background: var(--green); }

  /* ─── Header ────────────────────────────────────────────────────────── */
  .header {
    position: fixed;
    inset-inline: 0;
    top: 0;
    height: var(--header-h);
    background: rgba(245, 244, 240, 0.85);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border-bottom: 1px solid var(--border);
    z-index: 100;
    display: flex;
    align-items: center;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 2px;
    text-decoration: none;
    color: var(--dark);
  }

  .logo-img {
    height: 28px;
    width: auto;
    display: block;
    flex-shrink: 0;
  }

  .logo-img-footer {
    height: 26px;
  }

  .logo-wordmark {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--dark);
  }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .nav-link:hover { color: var(--dark); }

  /* ─── Buttons ───────────────────────────────────────────────────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    border-radius: 100px;
    font-family: var(--sans);
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease, border-color 0.15s ease;
    cursor: pointer;
    border: none;
    line-height: 1;
  }
  .btn:hover  { transform: translateY(-1px); }
  .btn:active { transform: translateY(0); }

  .btn-sm  { padding: 0.6em 1.4em;  font-size: 0.825rem; }
  .btn-lg  { padding: 0.78em 1.8em;  font-size: 1rem; }

  .btn-primary {
    background: var(--blue);
    color: white;
    box-shadow: 0 1px 6px rgba(66, 133, 244, 0.28);
  }
  .btn-primary:hover {
    box-shadow: 0 4px 18px rgba(66, 133, 244, 0.42);
  }

  .btn-ghost {
    background: transparent;
    color: var(--dark);
    border: 1.5px solid rgba(0, 0, 0, 0.2);
  }
  .btn-ghost:hover {
    border-color: var(--dark);
    background: rgba(0, 0, 0, 0.04);
  }

  /* ─── Hero ──────────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-top: var(--header-h);
    overflow: hidden;
  }

  .hero-illustration {
    position: absolute;
    right: clamp(-80px, -4vw, -20px);
    bottom: 0;
    width: clamp(480px, 62vw, 900px);
    pointer-events: none;
    z-index: 0;
    animation: fadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 0.45s;
  }

  .hero-illustration svg,
  .hero-illustration img {
    width: 100%;
    height: auto;
    display: block;
  }

  .hero .container {
    position: relative;
    z-index: 1;
    padding-top: 5.5rem;
    padding-bottom: 6rem;
  }

  .hero-content {
    max-width: 640px;
  }

  .hero-heading {
    font-size: clamp(3rem, 7.5vw, 6rem);
    font-weight: 800;
    line-height: 1.0;
    letter-spacing: -0.04em;
    color: var(--dark);
    margin-bottom: 1.5rem;
    animation: fadeUp 0.65s ease both;
    animation-delay: 0.1s;
  }

  .hero-body {
    font-size: clamp(1rem, 1.6vw, 1.125rem);
    line-height: 1.72;
    color: var(--muted);
    margin-bottom: 2.5rem;
    max-width: 480px;
    font-weight: 400;
    animation: fadeUp 0.65s ease both;
    animation-delay: 0.25s;
  }

  .hero .btn {
    animation: fadeUp 0.65s ease both;
    animation-delay: 0.4s;
  }

  /* ─── Keyframes ─────────────────────────────────────────────────────── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(22px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ─── Sections ──────────────────────────────────────────────────────── */
  .section {
    padding-block: clamp(4.5rem, 8vw, 7rem);
  }

  .section-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--dark);
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  /* ─── Community (dark typographic) ──────────────────────────────────── */
  .section-community {
    background: var(--dark);
    padding-block: clamp(3.5rem, 6vw, 5.5rem);
  }

  .community-label {
    font-family: var(--mono);
    font-size: 0.68rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.3);
    margin-bottom: 1.5rem;
  }

  .community-links-big {
    display: flex;
    flex-direction: column;
  }

  .big-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 1.1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    text-decoration: none;
    color: white;
    font-size: clamp(2rem, 5vw, 3.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    transition: color 0.2s ease;
  }

  .big-link:last-child {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .big-link svg {
    flex-shrink: 0;
    opacity: 0;
    transform: translate(-6px, 6px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .big-link:hover svg {
    opacity: 1;
    transform: translate(0, 0);
  }

  .big-link[data-accent="meetup"]:hover   { color: #E51937; }
  .big-link[data-accent="linkedin"]:hover { color: #0A66C2; }

  .big-link[data-accent="instagram"]:hover span {
    background: linear-gradient(90deg, #F58529, #DD2A7B, #8134AF);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .big-link[data-accent="instagram"]:hover svg {
    color: #DD2A7B;
  }

  /* ─── About ─────────────────────────────────────────────────────────── */
  .about-wrap {
    max-width: 720px;
  }

  .about-body .section-title {
    margin-bottom: 1.5rem;
  }

  .about-text-group {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .about-text-group p {
    font-size: 1.05rem;
    line-height: 1.78;
    color: #4a4a4a;
    font-weight: 400;
  }

  .about-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .about-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--muted);
    text-decoration: none;
    transition: gap 0.2s ease, color 0.15s ease;
  }

  .about-link:hover { gap: 0.7rem; color: var(--dark); }

  .about-link-primary {
    color: var(--blue);
  }

  .about-link-primary:hover { color: var(--blue); }

  /* ─── Footer ────────────────────────────────────────────────────────── */
  .footer {
    background: var(--dark);
    color: rgba(255, 255, 255, 0.65);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding-top: 3.5rem;
    padding-bottom: 3rem;
  }

  @media (min-width: 640px) {
    .footer-inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
    }
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 2px;
    margin-bottom: 0.75rem;
  }

  .footer-wordmark {
    font-size: 0.95rem;
    font-weight: 700;
    color: white;
  }

  .footer-tagline {
    font-size: 0.775rem;
    color: rgba(255, 255, 255, 0.32);
    max-width: 240px;
    line-height: 1.7;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    align-items: flex-start;
  }

  @media (min-width: 640px) {
    .footer-links { align-items: flex-end; }
  }

  .footer-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.52);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .footer-link:hover { color: white; }

  .footer-base {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-block: 1.25rem;
  }

  .footer-legal {
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.22);
    line-height: 1.65;
  }

  /* ─── Responsive ────────────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .header-nav .nav-link { display: none; }
    .hero-illustration { display: none; }
  }

  @media (min-width: 641px) and (max-width: 900px) {
    .hero-illustration {
      width: clamp(360px, 52vw, 560px);
      opacity: 0.6;
    }
  }

  /* ─── Reduced motion ────────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
